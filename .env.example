# Copia este archivo como .env y completa tus credenciales
# NUNCA subas el archivo .env al repositorio

# Entorno de ejecución: local | saucelabs
APPIUM_ENV=local

# Credenciales Sauce Labs (solo necesarias cuando APPIUM_ENV=saucelabs)
SAUCE_USERNAME=tu_usuario_aqui
SAUCE_ACCESS_KEY=tu_access_key_aqui
